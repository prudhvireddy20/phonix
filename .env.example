# ── MinIO (only needed for Docker-compose local deployment) ────────────────────
# Leave these blank/unset for cloud deployment (Northflank) — local storage used.
MINIO_ROOT_USER=phonix
MINIO_ROOT_PASSWORD=phonix_secret_change_me

# ── PostgreSQL (audit log) ────────────────────────────────────────────────────
# For Neon: postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
POSTGRES_DB=phonix
POSTGRES_USER=phonix
POSTGRES_PASSWORD=phonix_pg_change_me
POSTGRES_DSN=postgresql://phonix:phonix_pg_change_me@postgres:5432/phonix

# ── OpenRouter (LLM feedback — optional, scoring works without it) ────────────
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# ── Whisper (on-device) ───────────────────────────────────────────────────────
# tiny=75MB/~1s  base=145MB/~2s  small=480MB/~4s  medium=1.5GB/~10s
WHISPER_MODEL_SIZE=base

# ── App ───────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed by FastAPI CORS.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# URL the browser uses to reach the FastAPI backend.
# Leave blank for Docker (nginx proxies), set to backend URL for cloud.
NEXT_PUBLIC_BACKEND_URL=
